{
  "name": "@dokmatiq/docgen",
  "version": "0.1.0",
  "description": "TypeScript SDK for the Dokmatiq DocGen document generation API",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.cjs.json && echo '{\"type\":\"commonjs\"}' > dist/cjs/package.json",
    "build:esm": "tsc -p tsconfig.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "dokmatiq",
    "docgen",
    "pdf",
    "document-generation",
    "invoice",
    "zugferd",
    "xrechnung"
  ],
  "author": "Dokmatiq GmbH",
  "license": "MIT",
  "homepage": "https://github.com/dokmatiq/docgen-sdks/tree/main/typescript#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dokmatiq/docgen-sdks.git",
    "directory": "typescript"
  },
  "bugs": {
    "url": "https://github.com/dokmatiq/docgen-sdks/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^5.5.0"
  }
}
